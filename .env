BETTER_AUTH_SECRET=A2ZSwXFr9PeFFEl6EyBhhW1RmdpWVLBA1igF0zsfBm0=
BETTER_AUTH_URL=http://localhost:3000  # App URL (change for production)

# ─── Encryption (CLOUD-001/002) ────────────────────────────────
TOTP_ENCRYPTION_KEY=dc197c11f355e172fccce1dd73c40d6bf5a30e5cc890853fe46d108952929528

# ─── Email (optional in dev — logs to console without it) ────────
RESEND_API_KEY=re_...                  # Resend API key (https://resend.com/)
EMAIL_FROM=Claudit <noreply@claudit.consulting>

# ─── OAuth providers (optional — email/password works without these)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000  # Used by auth client and CORS origin validation

# ─── OAuth visibility (set to "true" when provider credentials above are configured)
NEXT_PUBLIC_GITHUB_ENABLED=false
NEXT_PUBLIC_GOOGLE_ENABLED=false

# ─── Security / Admin (required in production — CLOUD-008) ──────
HEALTH_SECRET=e9745f2cb40c55a13757bcc267aa17f6
REVALIDATION_SECRET=                      # Secret for on-demand ISR revalidation
API_ACCESS_TOKEN=                         # Bearer token for API access control

# ─── Redis (CLOUD-019 — required for cross-replica rate limiting)
UPSTASH_REDIS_REST_URL=                   # Upstash Redis REST URL (https://console.upstash.com/)
UPSTASH_REDIS_REST_TOKEN=                 # Upstash Redis REST token

# ─── Analytics (optional — no tracking without it) ───────────────
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=             # e.g. claudit.consulting (https://plausible.io/)

# ─── Deployment ──────────────────────────────────────────────────
RAILWAY_PUBLIC_DOMAIN=                    # Set automatically by Railway; used for CORS origins
