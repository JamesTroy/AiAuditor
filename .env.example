# ─── Required ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...           # Claude API key (https://console.anthropic.com/)
DATABASE_URL=postgresql://...          # Supabase PostgreSQL connection string
BETTER_AUTH_SECRET=                    # Random 32+ char secret (openssl rand -base64 32)
BETTER_AUTH_URL=http://localhost:3000  # App URL (change for production)

# ─── Email (optional in dev — logs to console without it) ────────
RESEND_API_KEY=re_...                  # Resend API key (https://resend.com/)
EMAIL_FROM=Claudit <noreply@claudit.consulting>

# ─── OAuth providers (optional — email/password works without these)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000  # Used by auth client
